# PostgreSQL connection string
# Пример Supabase: postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
# Пример Neon:     postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# JWT secret — придумайте любую длинную случайную строку
JWT_SECRET=your_super_secret_random_string_here_change_me

# Порт (Railway / Render подставят PORT автоматически)
PORT=4000
